name: signed release candidate

on:
  workflow_dispatch:
    inputs:
      create_draft:
        description: Create a private draft prerelease after all gates pass
        required: true
        type: boolean
        default: false

permissions:
  contents: read

concurrency:
  group: signed-release-candidate-${{ github.ref }}
  cancel-in-progress: false

env:
  VERSION: 0.2.0
  CARGO_TERM_COLOR: always

jobs:
  validate:
    if: ${{ github.ref == 'refs/heads/main' && github.repository == 'airwiki/airwiki' }}
    strategy:
      fail-fast: false
      matrix:
        os: [macos-15, windows-2025]
    runs-on: ${{ matrix.os }}
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          ref: ${{ github.sha }}
          persist-credentials: false
      - name: Install pinned Rust toolchain
        shell: bash
        run: rustup toolchain install 1.96.1 --profile minimal --component rustfmt,clippy
      - name: Install cargo-deny
        shell: bash
        run: cargo install cargo-deny --version 0.20.2 --locked
      - name: Format
        shell: bash
        run: cargo fmt --all -- --check
      - name: Clippy
        shell: bash
        run: cargo clippy --workspace --all-targets --all-features --locked -- -D warnings
      - name: Tests
        shell: bash
        run: cargo test --workspace --all-features --locked
      - name: License inventory
        shell: bash
        run: cargo run --locked -p xtask -- licenses check
      - name: Dependency policy
        shell: bash
        run: cargo deny --locked check

  macos:
    if: ${{ github.ref == 'refs/heads/main' && github.repository == 'airwiki/airwiki' }}
    needs: validate
    runs-on: macos-15
    environment: release-signing
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          ref: ${{ github.sha }}
          persist-credentials: false
      - name: Install pinned toolchain and packager
        shell: bash
        run: |
          rustup toolchain install 1.96.1 --profile minimal
          cargo install cargo-packager --version 0.11.8 --locked
      - name: Import Developer ID certificate
        shell: bash
        env:
          APPLE_CERTIFICATE_BASE64: ${{ secrets.APPLE_DEVELOPER_ID_P12_BASE64 }}
          APPLE_CERTIFICATE_PASSWORD: ${{ secrets.APPLE_DEVELOPER_ID_P12_PASSWORD }}
          KEYCHAIN_PASSWORD: ${{ secrets.MACOS_CI_KEYCHAIN_PASSWORD }}
        run: |
          test -n "$APPLE_CERTIFICATE_BASE64"
          test -n "$APPLE_CERTIFICATE_PASSWORD"
          test -n "$KEYCHAIN_PASSWORD"
          printf '%s' "$APPLE_CERTIFICATE_BASE64" | base64 --decode > "$RUNNER_TEMP/developer-id.p12"
          security create-keychain -p "$KEYCHAIN_PASSWORD" "$RUNNER_TEMP/release.keychain-db"
          security default-keychain -s "$RUNNER_TEMP/release.keychain-db"
          security unlock-keychain -p "$KEYCHAIN_PASSWORD" "$RUNNER_TEMP/release.keychain-db"
          security import "$RUNNER_TEMP/developer-id.p12" \
            -k "$RUNNER_TEMP/release.keychain-db" \
            -P "$APPLE_CERTIFICATE_PASSWORD" \
            -T /usr/bin/codesign \
            -T /usr/bin/security
          security set-key-partition-list -S apple-tool:,apple: -s \
            -k "$KEYCHAIN_PASSWORD" "$RUNNER_TEMP/release.keychain-db"
          rm -f "$RUNNER_TEMP/developer-id.p12"
      - name: Materialize temporary notarization key
        shell: bash
        env:
          APPLE_API_KEY_BASE64: ${{ secrets.APPLE_NOTARY_API_KEY_BASE64 }}
        run: |
          test -n "$APPLE_API_KEY_BASE64"
          printf '%s' "$APPLE_API_KEY_BASE64" | base64 --decode > "$RUNNER_TEMP/notary-api-key.p8"
          chmod 0600 "$RUNNER_TEMP/notary-api-key.p8"
          echo "APPLE_API_KEY_PATH=$RUNNER_TEMP/notary-api-key.p8" >> "$GITHUB_ENV"
      - name: Build, sign, notarize and staple macOS release
        shell: bash
        env:
          AIRWIKI_SIGNING_IDENTITY: ${{ vars.MACOS_SIGNING_IDENTITY }}
          APPLE_API_KEY_ID: ${{ secrets.APPLE_NOTARY_API_KEY_ID }}
          APPLE_API_ISSUER_ID: ${{ secrets.APPLE_NOTARY_API_ISSUER_ID }}
          CARGO_PACKAGER_SIGN_PRIVATE_KEY: ${{ secrets.UPDATER_PRIVATE_KEY }}
          CARGO_PACKAGER_SIGN_PRIVATE_KEY_PASSWORD: ${{ secrets.UPDATER_PRIVATE_KEY_PASSWORD }}
          AIRWIKI_UPDATE_ENDPOINT: https://github.com/${{ github.repository }}/releases/latest/download/latest.json
          AIRWIKI_UPDATER_PUBLIC_KEY: ${{ vars.UPDATER_PUBLIC_KEY }}
        run: ./packaging/release-macos.sh
      - name: Upload final macOS bytes
        uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02 # v4
        with:
          name: airwiki-macos-arm64-${{ env.VERSION }}
          if-no-files-found: error
          path: |
            target/packages/macos/AirWiki_0.2.0_aarch64.dmg
            target/packages/macos/AirWiki.app.tar.gz
            target/packages/macos/AirWiki.app.tar.gz.sig
      - name: Remove temporary signing material
        if: always()
        shell: bash
        run: |
          rm -f "$RUNNER_TEMP/notary-api-key.p8" "$RUNNER_TEMP/developer-id.p12"
          security delete-keychain "$RUNNER_TEMP/release.keychain-db" 2>/dev/null || true

  windows-build:
    if: ${{ github.ref == 'refs/heads/main' && github.repository == 'airwiki/airwiki' }}
    needs: validate
    runs-on: windows-2025
    permissions:
      contents: read
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          ref: ${{ github.sha }}
          persist-credentials: false
      - name: Install pinned toolchain and packager
        shell: pwsh
        run: |
          rustup toolchain install 1.96.1 --profile minimal
          cargo install cargo-packager --version 0.11.8 --locked
      - name: Build unsigned Windows artifacts and isolated release tools
        shell: pwsh
        env:
          AIRWIKI_UPDATE_ENDPOINT: https://github.com/${{ github.repository }}/releases/latest/download/latest.json
          AIRWIKI_UPDATER_PUBLIC_KEY: ${{ vars.UPDATER_PUBLIC_KEY }}
        run: |
          $SevenZipRoot = "target\verified-tools\7zip-26.02"
          ./packaging/prepare-verified-7zip.ps1 -ToolRoot $SevenZipRoot
          ./packaging/prepare-windows-release.ps1
          cargo build --locked --release -p xtask
          if ($LASTEXITCODE -ne 0) { throw "release tool build failed" }

          $Handoff = "target\windows-build-handoff"
          Remove-Item -LiteralPath $Handoff -Recurse -Force -ErrorAction SilentlyContinue
          New-Item -ItemType Directory -Path `
            "$Handoff\product", `
            "$Handoff\runtime", `
            "$Handoff\tools", `
            "$Handoff\tools\7zip-26.02" | Out-Null
          $Expected = @(
            "airwiki.exe",
            "airwiki-mcp-bridge.exe",
            "airwiki-windows-firewall-helper.exe"
          )
          foreach ($Name in $Expected) {
            Copy-Item -LiteralPath "target\x86_64-pc-windows-msvc\release\$Name" -Destination "$Handoff\product\$Name"
          }
          Copy-Item -Path "resources\llama\windows-x64\*" -Destination "$Handoff\runtime" -Recurse
          Copy-Item -LiteralPath "target\release\xtask.exe" -Destination "$Handoff\tools\xtask.exe"
          Copy-Item -LiteralPath (Get-Command cargo-packager.exe -ErrorAction Stop).Source `
            -Destination "$Handoff\tools\cargo-packager.exe"
          ./packaging/prepare-verified-7zip.ps1 -ToolRoot $SevenZipRoot -ValidateOnly
          Copy-Item -Path "$SevenZipRoot\*" -Destination "$Handoff\tools\7zip-26.02"

          $ProductNames = @(Get-ChildItem -LiteralPath "$Handoff\product" -File | ForEach-Object Name | Sort-Object)
          if (Compare-Object ($Expected | Sort-Object) $ProductNames) {
            throw "unsigned product handoff has an unexpected file set"
          }
          if (-not (Test-Path -LiteralPath "$Handoff\runtime\llama-server.exe" -PathType Leaf)) {
            throw "verified llama.cpp runtime is missing from the unsigned handoff"
          }
      - name: Upload immutable unsigned Windows handoff
        uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02 # v4
        with:
          name: airwiki-windows-unsigned-${{ env.VERSION }}-${{ github.sha }}
          if-no-files-found: error
          retention-days: 1
          path: target/windows-build-handoff

  windows-authenticode:
    if: ${{ github.ref == 'refs/heads/main' && github.repository == 'airwiki/airwiki' }}
    needs: windows-build
    runs-on: windows-2025
    environment: release-signing
    permissions:
      contents: read
      id-token: write
    steps:
      - name: Download immutable unsigned Windows handoff
        uses: actions/download-artifact@d3f86a106a0bac45b974a628896c90dbdf5c8093 # v4
        with:
          name: airwiki-windows-unsigned-${{ env.VERSION }}-${{ github.sha }}
          path: handoff
      - name: Materialize only the nested executables
        shell: pwsh
        run: |
          $Release = "target\x86_64-pc-windows-msvc\release"
          New-Item -ItemType Directory -Path $Release -Force | Out-Null
          Copy-Item -Path "handoff\product\*" -Destination $Release
      - name: Authenticate to Azure with OIDC
        uses: azure/login@532459ea530d8321f2fb9bb10d1e0bcf23869a43 # v3
        with:
          client-id: ${{ secrets.AZURE_CLIENT_ID }}
          tenant-id: ${{ secrets.AZURE_TENANT_ID }}
          subscription-id: ${{ secrets.AZURE_SUBSCRIPTION_ID }}
      - name: Sign nested Windows executables
        uses: azure/artifact-signing-action@c7ab2a863ab5f9a846ddb8265964877ef296ee82 # v2
        with:
          endpoint: ${{ vars.AZURE_ARTIFACT_SIGNING_ENDPOINT }}
          signing-account-name: ${{ vars.AZURE_ARTIFACT_SIGNING_ACCOUNT }}
          certificate-profile-name: ${{ vars.AZURE_ARTIFACT_SIGNING_PROFILE }}
          files-folder: ${{ github.workspace }}\target\x86_64-pc-windows-msvc\release
          files-folder-filter: exe,dll
          file-digest: SHA256
          timestamp-rfc3161: http://timestamp.acs.microsoft.com
          timestamp-digest: SHA256
      - name: Stage only the signed nested executables
        shell: pwsh
        run: |
          $Handoff = "target\windows-nested-signed-handoff"
          Remove-Item -LiteralPath $Handoff -Recurse -Force -ErrorAction SilentlyContinue
          New-Item -ItemType Directory -Path "$Handoff\product" -Force | Out-Null
          Copy-Item -LiteralPath "target\x86_64-pc-windows-msvc\release\airwiki.exe" -Destination "$Handoff\product"
          Copy-Item -LiteralPath "target\x86_64-pc-windows-msvc\release\airwiki-mcp-bridge.exe" -Destination "$Handoff\product"
          Copy-Item -LiteralPath "target\x86_64-pc-windows-msvc\release\airwiki-windows-firewall-helper.exe" -Destination "$Handoff\product"
      - name: Upload immutable nested-signature handoff
        uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02 # v4
        with:
          name: airwiki-windows-nested-signed-${{ env.VERSION }}-${{ github.sha }}
          if-no-files-found: error
          retention-days: 1
          path: target/windows-nested-signed-handoff

  windows-assemble:
    if: ${{ github.ref == 'refs/heads/main' && github.repository == 'airwiki/airwiki' }}
    needs: windows-authenticode
    runs-on: windows-2025
    permissions:
      contents: read
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          ref: ${{ github.sha }}
          persist-credentials: false
      - name: Download immutable nested-signature handoff
        uses: actions/download-artifact@d3f86a106a0bac45b974a628896c90dbdf5c8093 # v4
        with:
          name: airwiki-windows-nested-signed-${{ env.VERSION }}-${{ github.sha }}
          path: signed
      - name: Download original tools from the secret-free build
        uses: actions/download-artifact@d3f86a106a0bac45b974a628896c90dbdf5c8093 # v4
        with:
          name: airwiki-windows-unsigned-${{ env.VERSION }}-${{ github.sha }}
          path: unsigned
      - name: Build and verify MCPB without signing credentials
        shell: pwsh
        env:
          AIRWIKI_WINDOWS_SIGNER_IDENTITY: ${{ vars.WINDOWS_SIGNER_IDENTITY }}
        run: |
          $Release = "target\x86_64-pc-windows-msvc\release"
          $Mcpb = "target\mcpb\x86_64-pc-windows-msvc\airwiki-claude.mcpb"
          New-Item -ItemType Directory -Path $Release, (Split-Path -Parent $Mcpb) -Force | Out-Null
          Copy-Item -Path "signed\product\*" -Destination $Release
          . ./packaging/windows-signing.ps1
          $Expected = Assert-ExpectedWindowsSigner "$Release\airwiki.exe"
          $Bridge = Assert-ExpectedWindowsSigner "$Release\airwiki-mcp-bridge.exe"
          $Helper = Assert-ExpectedWindowsSigner "$Release\airwiki-windows-firewall-helper.exe"
          Assert-SameWindowsSigner $Expected $Bridge "MCP bridge"
          Assert-SameWindowsSigner $Expected $Helper "firewall helper"

          & "unsigned\tools\xtask.exe" packaging verify-windows-uninstaller
          if ($LASTEXITCODE -ne 0) { throw "Windows uninstaller policy validation failed" }
          & "unsigned\tools\xtask.exe" mcpb build `
            --target x86_64-pc-windows-msvc `
            --bridge "$Release\airwiki-mcp-bridge.exe" `
            --output $Mcpb
          if ($LASTEXITCODE -ne 0) { throw "Claude MCPB build failed" }
          & "unsigned\tools\xtask.exe" mcpb verify `
            --target x86_64-pc-windows-msvc `
            --bridge "$Release\airwiki-mcp-bridge.exe" `
            --output $Mcpb
          if ($LASTEXITCODE -ne 0) { throw "Claude MCPB verification failed" }
      - name: Stage verified package inputs
        shell: pwsh
        run: |
          $Handoff = "target\windows-assembled-handoff"
          Remove-Item -LiteralPath $Handoff -Recurse -Force -ErrorAction SilentlyContinue
          New-Item -ItemType Directory -Path `
            "$Handoff\product", `
            "$Handoff\mcpb" -Force | Out-Null
          Copy-Item -Path "signed\product\*" -Destination "$Handoff\product"
          Copy-Item -LiteralPath "target\mcpb\x86_64-pc-windows-msvc\airwiki-claude.mcpb" -Destination "$Handoff\mcpb"
      - name: Upload immutable assembled Windows handoff
        uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02 # v4
        with:
          name: airwiki-windows-assembled-${{ env.VERSION }}-${{ github.sha }}
          if-no-files-found: error
          retention-days: 1
          path: target/windows-assembled-handoff

  windows-package:
    if: ${{ github.ref == 'refs/heads/main' && github.repository == 'airwiki/airwiki' }}
    needs: windows-assemble
    runs-on: windows-2025
    environment: release-signing
    permissions:
      contents: read
      id-token: write
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          ref: ${{ github.sha }}
          persist-credentials: false
      - name: Install isolated pinned Windows packager
        shell: pwsh
        run: |
          rustup toolchain install 1.96.1 --profile minimal
          $PackagerRoot = Join-Path $env:RUNNER_TEMP "cargo-packager-0.11.8"
          cargo install cargo-packager --version 0.11.8 --locked --root $PackagerRoot
          if ($LASTEXITCODE -ne 0) { throw "isolated cargo-packager installation failed" }
          $Packager = (Resolve-Path -LiteralPath "$PackagerRoot\bin\cargo-packager.exe").Path
          $Version = (& $Packager --version | Out-String).Trim()
          if ($LASTEXITCODE -ne 0 -or $Version -ne "cargo-packager 0.11.8") {
            throw "isolated cargo-packager version mismatch"
          }
          "AIRWIKI_CARGO_PACKAGER=$Packager" | Out-File -FilePath $env:GITHUB_ENV -Encoding utf8 -Append
      - name: Prepare SHA-256-pinned NSIS toolchain
        shell: pwsh
        run: |
          $ToolCache = Join-Path ([Environment]::GetFolderPath("LocalApplicationData")) ".cargo-packager"
          ./packaging/prepare-verified-nsis-toolchain.ps1 -ToolCacheRoot $ToolCache
      - name: Download immutable assembled Windows handoff
        uses: actions/download-artifact@d3f86a106a0bac45b974a628896c90dbdf5c8093 # v4
        with:
          name: airwiki-windows-assembled-${{ env.VERSION }}-${{ github.sha }}
          path: assembled
      - name: Download original runtime from the secret-free build
        uses: actions/download-artifact@d3f86a106a0bac45b974a628896c90dbdf5c8093 # v4
        with:
          name: airwiki-windows-unsigned-${{ env.VERSION }}-${{ github.sha }}
          path: unsigned
      - name: Materialize preverified package inputs
        shell: pwsh
        run: |
          New-Item -ItemType Directory -Path `
            "target\x86_64-pc-windows-msvc\release", `
            "resources\llama\windows-x64", `
            "target\mcpb\x86_64-pc-windows-msvc", `
            "$env:RUNNER_TEMP\release-tools" -Force | Out-Null
          Copy-Item -Path "assembled\product\*" -Destination "target\x86_64-pc-windows-msvc\release"
          Copy-Item -Path "unsigned\runtime\*" -Destination "resources\llama\windows-x64" -Recurse
          Copy-Item -LiteralPath "assembled\mcpb\airwiki-claude.mcpb" -Destination "target\mcpb\x86_64-pc-windows-msvc"
          $PackagerLiteral = $env:AIRWIKI_CARGO_PACKAGER.Replace("'", "''")
          $CargoShim = @'
          param([Parameter(Position = 0, ValueFromRemainingArguments = $true)][string[]] $CargoArgs)
          $ErrorActionPreference = "Stop"
          if ($CargoArgs.Count -lt 2 -or $CargoArgs[0] -ne "packager") {
              throw "release Cargo shim permits only cargo-packager"
          }
          $Packager = '__AIRWIKI_CARGO_PACKAGER__'
          & $Packager @($CargoArgs[1..($CargoArgs.Count - 1)])
          exit $LASTEXITCODE
          '@
          $CargoShim.Replace('__AIRWIKI_CARGO_PACKAGER__', $PackagerLiteral) | `
            Set-Content -LiteralPath "$env:RUNNER_TEMP\release-tools\cargo-shim.ps1" -Encoding UTF8
          @'
          @echo off
          powershell.exe -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File "%~dp0cargo-shim.ps1" %*
          exit /b %ERRORLEVEL%
          '@ | Set-Content -LiteralPath "$env:RUNNER_TEMP\release-tools\cargo.cmd" -Encoding ASCII
          "$env:RUNNER_TEMP\release-tools" | Out-File -FilePath $env:GITHUB_PATH -Encoding utf8 -Append
          New-Item -ItemType Directory -Path "$env:RUNNER_TEMP\artifact-signing-probe" | Out-Null
          Copy-Item -LiteralPath "target\x86_64-pc-windows-msvc\release\airwiki.exe" `
            -Destination "$env:RUNNER_TEMP\artifact-signing-probe\probe.exe"
      - name: Authenticate package signer to Azure with OIDC
        uses: azure/login@532459ea530d8321f2fb9bb10d1e0bcf23869a43 # v3
        with:
          client-id: ${{ secrets.AZURE_CLIENT_ID }}
          tenant-id: ${{ secrets.AZURE_TENANT_ID }}
          subscription-id: ${{ secrets.AZURE_SUBSCRIPTION_ID }}
      - name: Initialize the pinned Artifact Signing toolchain on a disposable copy
        uses: azure/artifact-signing-action@c7ab2a863ab5f9a846ddb8265964877ef296ee82 # v2
        with:
          endpoint: ${{ vars.AZURE_ARTIFACT_SIGNING_ENDPOINT }}
          signing-account-name: ${{ vars.AZURE_ARTIFACT_SIGNING_ACCOUNT }}
          certificate-profile-name: ${{ vars.AZURE_ARTIFACT_SIGNING_PROFILE }}
          files-folder: ${{ runner.temp }}\artifact-signing-probe
          files-folder-filter: exe
          file-digest: SHA256
          timestamp-rfc3161: http://timestamp.acs.microsoft.com
          timestamp-digest: SHA256
      - name: Remove disposable signing probe
        shell: pwsh
        run: Remove-Item -LiteralPath "$env:RUNNER_TEMP\artifact-signing-probe" -Recurse -Force
      - name: Package preverified inputs and sign generated PE files
        shell: pwsh
        env:
          AIRWIKI_USE_PREBUILT_MCPB: "true"
          AIRWIKI_WINDOWS_SIGNER_IDENTITY: ${{ vars.WINDOWS_SIGNER_IDENTITY }}
          AIRWIKI_ARTIFACT_SIGNING_ENDPOINT: ${{ vars.AZURE_ARTIFACT_SIGNING_ENDPOINT }}
          AIRWIKI_ARTIFACT_SIGNING_ACCOUNT: ${{ vars.AZURE_ARTIFACT_SIGNING_ACCOUNT }}
          AIRWIKI_ARTIFACT_SIGNING_PROFILE: ${{ vars.AZURE_ARTIFACT_SIGNING_PROFILE }}
        run: ./packaging/package-signed-windows.ps1
      - name: Stage Authenticode package for the isolated updater signer
        shell: pwsh
        run: |
          $Handoff = "target\windows-packaged-handoff"
          Remove-Item -LiteralPath $Handoff -Recurse -Force -ErrorAction SilentlyContinue
          New-Item -ItemType Directory -Path `
            "$Handoff\uninstaller", `
            "$Handoff\installer" -Force | Out-Null
          Copy-Item -LiteralPath "target\windows-uninstaller\airwiki-uninstall.exe" -Destination "$Handoff\uninstaller"
          Copy-Item -LiteralPath "target\packages\windows\airwiki_0.2.0_x64-setup.exe" -Destination "$Handoff\installer"
      - name: Upload immutable Authenticode package handoff
        uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02 # v4
        with:
          name: airwiki-windows-authenticode-${{ env.VERSION }}-${{ github.sha }}
          if-no-files-found: error
          retention-days: 1
          path: target/windows-packaged-handoff

  windows-updater-sign:
    if: ${{ github.ref == 'refs/heads/main' && github.repository == 'airwiki/airwiki' }}
    needs: windows-package
    runs-on: windows-2025
    environment: release-signing
    permissions:
      contents: read
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          ref: ${{ github.sha }}
          persist-credentials: false
      - name: Install isolated pinned updater signer
        shell: pwsh
        run: |
          rustup toolchain install 1.96.1 --profile minimal
          $PackagerRoot = Join-Path $env:RUNNER_TEMP "cargo-packager-0.11.8"
          cargo install cargo-packager --version 0.11.8 --locked --root $PackagerRoot
          if ($LASTEXITCODE -ne 0) { throw "isolated cargo-packager installation failed" }
          $Packager = (Resolve-Path -LiteralPath "$PackagerRoot\bin\cargo-packager.exe").Path
          $Version = (& $Packager --version | Out-String).Trim()
          if ($LASTEXITCODE -ne 0 -or $Version -ne "cargo-packager 0.11.8") {
            throw "isolated cargo-packager version mismatch"
          }
          "AIRWIKI_CARGO_PACKAGER=$Packager" | Out-File -FilePath $env:GITHUB_ENV -Encoding utf8 -Append
      - name: Download immutable Authenticode handoff
        uses: actions/download-artifact@d3f86a106a0bac45b974a628896c90dbdf5c8093 # v4
        with:
          name: airwiki-windows-authenticode-${{ env.VERSION }}-${{ github.sha }}
          path: packaged
      - name: Sign only the updater payload
        shell: pwsh
        env:
          CARGO_PACKAGER_SIGN_PRIVATE_KEY: ${{ secrets.UPDATER_PRIVATE_KEY }}
          CARGO_PACKAGER_SIGN_PRIVATE_KEY_PASSWORD: ${{ secrets.UPDATER_PRIVATE_KEY_PASSWORD }}
        run: |
          $Installer = Get-Item -LiteralPath "packaged\installer\airwiki_0.2.0_x64-setup.exe"
          & $env:AIRWIKI_CARGO_PACKAGER signer sign $Installer.FullName
          if ($LASTEXITCODE -ne 0) { throw "updater signing failed" }
          if (-not (Test-Path -LiteralPath "$($Installer.FullName).sig" -PathType Leaf)) {
            throw "updater signer did not create the detached signature"
          }
      - name: Upload immutable updater-signed handoff
        uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02 # v4
        with:
          name: airwiki-windows-updater-signed-${{ env.VERSION }}-${{ github.sha }}
          if-no-files-found: error
          retention-days: 1
          path: packaged/installer/airwiki_0.2.0_x64-setup.exe.sig

  windows:
    if: ${{ github.ref == 'refs/heads/main' && github.repository == 'airwiki/airwiki' }}
    needs: windows-updater-sign
    runs-on: windows-2025
    permissions:
      contents: read
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          ref: ${{ github.sha }}
          persist-credentials: false
      - name: Download immutable updater-signed handoff
        uses: actions/download-artifact@d3f86a106a0bac45b974a628896c90dbdf5c8093 # v4
        with:
          name: airwiki-windows-updater-signed-${{ env.VERSION }}-${{ github.sha }}
          path: updater-signature
      - name: Download immutable Authenticode package
        uses: actions/download-artifact@d3f86a106a0bac45b974a628896c90dbdf5c8093 # v4
        with:
          name: airwiki-windows-authenticode-${{ env.VERSION }}-${{ github.sha }}
          path: packaged
      - name: Download independently assembled product and MCPB
        uses: actions/download-artifact@d3f86a106a0bac45b974a628896c90dbdf5c8093 # v4
        with:
          name: airwiki-windows-assembled-${{ env.VERSION }}-${{ github.sha }}
          path: assembled
      - name: Download original runtime and verifier from the secret-free build
        uses: actions/download-artifact@d3f86a106a0bac45b974a628896c90dbdf5c8093 # v4
        with:
          name: airwiki-windows-unsigned-${{ env.VERSION }}-${{ github.sha }}
          path: unsigned
      - name: Materialize final verification inputs without signing credentials
        shell: pwsh
        run: |
          New-Item -ItemType Directory -Path `
            "target\x86_64-pc-windows-msvc\release", `
            "resources\llama\windows-x64", `
            "target\mcpb\x86_64-pc-windows-msvc", `
            "target\windows-uninstaller", `
            "target\packages\windows", `
            "$env:RUNNER_TEMP\release-tools", `
            "$env:RUNNER_TEMP\release-tools\7zip-26.02" -Force | Out-Null
          Copy-Item -Path "assembled\product\*" -Destination "target\x86_64-pc-windows-msvc\release"
          Copy-Item -Path "unsigned\runtime\*" -Destination "resources\llama\windows-x64" -Recurse
          Copy-Item -LiteralPath "assembled\mcpb\airwiki-claude.mcpb" -Destination "target\mcpb\x86_64-pc-windows-msvc"
          Copy-Item -LiteralPath "packaged\uninstaller\airwiki-uninstall.exe" -Destination "target\windows-uninstaller"
          Copy-Item -LiteralPath "packaged\installer\airwiki_0.2.0_x64-setup.exe" -Destination "target\packages\windows"
          Copy-Item -LiteralPath "updater-signature\airwiki_0.2.0_x64-setup.exe.sig" -Destination "target\packages\windows"
          Copy-Item -LiteralPath "unsigned\tools\xtask.exe" -Destination "$env:RUNNER_TEMP\release-tools"
          Copy-Item -Path "unsigned\tools\7zip-26.02\*" -Destination "$env:RUNNER_TEMP\release-tools\7zip-26.02"
          ./packaging/prepare-verified-7zip.ps1 `
            -ToolRoot "$env:RUNNER_TEMP\release-tools\7zip-26.02" `
            -ValidateOnly
      - name: Verify final Windows bytes without signing credentials
        shell: pwsh
        env:
          AIRWIKI_UPDATER_PUBLIC_KEY: ${{ vars.UPDATER_PUBLIC_KEY }}
          AIRWIKI_WINDOWS_SIGNER_IDENTITY: ${{ vars.WINDOWS_SIGNER_IDENTITY }}
          AIRWIKI_XTASK: ${{ runner.temp }}\release-tools\xtask.exe
          AIRWIKI_7ZIP_ROOT: ${{ runner.temp }}\release-tools\7zip-26.02
        run: ./packaging/verify-windows-release.ps1
      - name: Verify clean install and materialized uninstaller
        shell: pwsh
        env:
          AIRWIKI_WINDOWS_SIGNER_IDENTITY: ${{ vars.WINDOWS_SIGNER_IDENTITY }}
        run: ./packaging/smoke-install-windows.ps1
      - name: Upload final Windows bytes
        uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02 # v4
        with:
          name: airwiki-windows-x64-${{ env.VERSION }}
          if-no-files-found: error
          path: |
            target/packages/windows/airwiki_0.2.0_x64-setup.exe
            target/packages/windows/airwiki_0.2.0_x64-setup.exe.sig

  candidate:
    if: ${{ github.ref == 'refs/heads/main' && github.repository == 'airwiki/airwiki' }}
    needs: [macos, windows]
    runs-on: ubuntu-24.04
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          ref: ${{ github.sha }}
          persist-credentials: false
      - name: Download final macOS artifacts only
        uses: actions/download-artifact@d3f86a106a0bac45b974a628896c90dbdf5c8093 # v4
        with:
          name: airwiki-macos-arm64-${{ env.VERSION }}
          path: downloaded/macos
      - name: Download final Windows artifacts only
        uses: actions/download-artifact@d3f86a106a0bac45b974a628896c90dbdf5c8093 # v4
        with:
          name: airwiki-windows-x64-${{ env.VERSION }}
          path: downloaded/windows
      - name: Flatten final artifacts and generate prerelease manifest
        shell: bash
        run: |
          mkdir release
          while IFS= read -r -d '' SOURCE; do
            DESTINATION="release/$(basename "$SOURCE")"
            test ! -e "$DESTINATION"
            cp "$SOURCE" "$DESTINATION"
          done < <(find downloaded -type f -print0)
          MAC_ARCHIVE='release/AirWiki.app.tar.gz'
          MAC_SIGNATURE='release/AirWiki.app.tar.gz.sig'
          WINDOWS_INSTALLER='release/airwiki_0.2.0_x64-setup.exe'
          WINDOWS_SIGNATURE='release/airwiki_0.2.0_x64-setup.exe.sig'
          test -f "$MAC_ARCHIVE" && test -f "$MAC_SIGNATURE"
          test -f "$WINDOWS_INSTALLER" && test -f "$WINDOWS_SIGNATURE"
          python3 - <<'PY'
          from pathlib import Path

          root = Path("release")
          expected = {
              "AirWiki_0.2.0_aarch64.dmg",
              "AirWiki.app.tar.gz",
              "AirWiki.app.tar.gz.sig",
              "airwiki_0.2.0_x64-setup.exe",
              "airwiki_0.2.0_x64-setup.exe.sig",
          }
          entries = list(root.iterdir())
          assert all(path.is_file() and not path.is_symlink() for path in entries)
          assert {path.name for path in entries} == expected, "release artifact allowlist mismatch"
          PY
          PUBLISHED_AT=$(date -u +%Y-%m-%dT%H:%M:%SZ)
          python3 packaging/generate-update-manifest.py \
            --version "$VERSION" \
            --published-at "$PUBLISHED_AT" \
            --base-url "https://github.com/$GITHUB_REPOSITORY/releases/download/v$VERSION" \
            --macos "$MAC_ARCHIVE" \
            --macos-signature "$MAC_SIGNATURE" \
            --windows "$WINDOWS_INSTALLER" \
            --windows-signature "$WINDOWS_SIGNATURE" \
            --output "release/prerelease-$VERSION.json"
      - name: Generate SPDX SBOM for final artifacts
        uses: anchore/sbom-action@e22c389904149dbc22b58101806040fa8d37a610 # v0
        with:
          path: release
          format: spdx-json
          output-file: release/airwiki-${{ env.VERSION }}.spdx.json
      - name: Hash final candidate bytes
        shell: bash
        run: |
          cd release
          find . -maxdepth 1 -type f -printf '%f\0' | sort -z | xargs -0 sha256sum \
            > "$RUNNER_TEMP/SHA256SUMS"
          mv "$RUNNER_TEMP/SHA256SUMS" "SHA256SUMS-$VERSION.txt"
          python3 - <<'PY'
          from pathlib import Path

          root = Path(".")
          expected = {
              "AirWiki_0.2.0_aarch64.dmg",
              "AirWiki.app.tar.gz",
              "AirWiki.app.tar.gz.sig",
              "airwiki_0.2.0_x64-setup.exe",
              "airwiki_0.2.0_x64-setup.exe.sig",
              "prerelease-0.2.0.json",
              "airwiki-0.2.0.spdx.json",
              "SHA256SUMS-0.2.0.txt",
          }
          entries = list(root.iterdir())
          assert all(path.is_file() and not path.is_symlink() for path in entries)
          assert {path.name for path in entries} == expected, "final candidate allowlist mismatch"
          PY
      - name: Upload candidate bundle
        uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02 # v4
        with:
          name: airwiki-signed-candidate-${{ env.VERSION }}
          if-no-files-found: error
          path: release

  draft:
    if: ${{ inputs.create_draft && github.ref == 'refs/heads/main' && github.repository == 'airwiki/airwiki' }}
    needs: candidate
    runs-on: ubuntu-24.04
    environment: release-signing
    permissions:
      contents: write
    steps:
      - uses: actions/checkout@93cb6efe18208431cddfb8368fd83d5badbf9bfd # v5
        with:
          ref: ${{ github.sha }}
          persist-credentials: false
      - uses: actions/download-artifact@d3f86a106a0bac45b974a628896c90dbdf5c8093 # v4
        with:
          name: airwiki-signed-candidate-${{ env.VERSION }}
          path: release
      - name: Require official project metadata before creating a draft
        shell: bash
        run: |
          EXPECTED="repository = \"https://github.com/$GITHUB_REPOSITORY\""
          grep -F "$EXPECTED" Cargo.toml
          ! grep -R -n 'transitional contact\|release blocker' SECURITY.md CODE_OF_CONDUCT.md
      - name: Create private draft prerelease
        env:
          GH_TOKEN: ${{ github.token }}
        shell: bash
        run: |
          mapfile -d '' ASSETS < <(find release -type f -print0)
          gh release create "v$VERSION" "${ASSETS[@]}" \
            --draft \
            --prerelease \
            --target "$GITHUB_SHA" \
            --title "AirWiki $VERSION release candidate" \
            --notes-file docs/release-notes/0.2.0.md
